 #include "arch.h"
 #include "klog.h" // IWYU pragma: keep
@@ -201,10 +204,47 @@ static void on_post_fs_data_cbfun(struct callback_head *cb)
 }
 
 static struct callback_head on_post_fs_data_cb = { .func =
 							on_post_fs_data_cbfun };
 
+// One-shot
+static atomic_t ksud_root_done = ATOMIC_INIT(0);
+
+// Delayed work
+static void ksud_dispatch_workfn(struct work_struct *work);
+static DECLARE_DELAYED_WORK(ksud_dispatch_work, ksud_dispatch_workfn);
+
+// Fallback dispatch
+static void ksud_dispatch_workfn(struct work_struct *work)
+{
+	// Check
+	if (atomic_read(&ksud_root_done))
+		return;
+
+	// Wait
+	if (!ksu_module_mounted || !ksu_boot_completed) {
+		schedule_delayed_work(&ksud_dispatch_work,
+					msecs_to_jiffies(1000));
+		return;
+	}
+
+	// Claim (one-shot); execute
+	if (atomic_cmpxchg(&ksud_root_done, 0, 1) != 0)
+		return;
+
+	pr_info("fallback dispatch (post-fs-data)\n");
+	on_post_fs_data();
+}
+
+static int __init ksud_dispatch_init(void)
+{
+	// Fallback scheduling (post late-init)
+	schedule_delayed_work(&ksud_dispatch_work, msecs_to_jiffies(500));
+	return 0;
+}
+late_initcall(ksud_dispatch_init);
